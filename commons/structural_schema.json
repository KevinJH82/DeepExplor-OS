{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Structural Interpretation Metadata",
  "description": "geo-stru 标准输出的 metadata.json 字段定义。地质构造解译产品(地形量算 + 线性体提取)遵循此 schema,供 geo-analyser / geo-exploration / geo-reporter 通过 AOI 目录 + bbox 相交发现并消费。",
  "type": "object",
  "required": [
    "source",
    "aoi_name",
    "aoi_bbox",
    "crs",
    "products"
  ],
  "properties": {
    "source": {
      "type": "string",
      "enum": ["geo-stru", "geo-stru-insar-fusion"],
      "description": "产品来源: geo-stru(构造解译) 或 geo-stru-insar-fusion(InSAR 融合)"
    },
    "source_version": {
      "type": ["string", "null"],
      "description": "geo-stru 处理流水线版本"
    },
    "run_id": {
      "type": ["string", "null"],
      "description": "本次分析的 run 标识(时间戳+task_code);产物存于 <AOI>/structural/<run_id>/,历史不覆盖"
    },
    "task_code": {
      "type": ["string", "null"],
      "description": "本次分析任务的全局唯一编码(形如 GST-YYYYMMDD-HHMMSS-XXXX);用于按编码回溯磁盘产物与日志"
    },
    "aoi_name": {
      "type": "string",
      "description": "AOI 名称(来自 KML <name>,回退文件名)"
    },
    "aoi_bbox": {
      "type": "array",
      "items": {"type": "number"},
      "minItems": 4,
      "maxItems": 4,
      "description": "[min_lon, min_lat, max_lon, max_lat]"
    },
    "crs": {
      "type": "string",
      "default": "EPSG:4326",
      "description": "输出栅格的 CRS"
    },
    "dem_shape": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 2,
      "maxItems": 2,
      "description": "[height, width] 裁剪后 DEM 像素尺寸"
    },
    "pixel_size_m": {
      "type": ["array", "null"],
      "items": {"type": "number"},
      "description": "[x, y] 像元地面尺寸(米)"
    },
    "products": {
      "type": "object",
      "description": "产品文件相对路径(相对 structural 目录)",
      "properties": {
        "hillshade": {"type": ["string", "null"]},
        "aspect": {"type": ["string", "null"]},
        "slope": {"type": ["string", "null"]},
        "curvature": {"type": ["string", "null"]},
        "svf": {"type": ["string", "null"]},
        "openness": {"type": ["string", "null"]},
        "distance_to_lineament": {"type": ["string", "null"]},
        "lineament_density": {"type": ["string", "null"]},
        "lineaments_geojson": {"type": ["string", "null"]},
        "rose_diagram": {"type": ["string", "null"]},
        "map_hillshade_png": {"type": ["string", "null"]},
        "map_aspect_png": {"type": ["string", "null"]},
        "map_terrain_png": {"type": ["string", "null"]},
        "los_velocity_mm_yr": {"type": ["string", "null"], "description": "InSAR LOS 速率 (mm/yr)"},
        "vertical_velocity_mm_yr": {"type": ["string", "null"], "description": "升降双轨 2D 分解垂直速率 (mm/yr)"},
        "ew_velocity_mm_yr": {"type": ["string", "null"], "description": "升降双轨 2D 分解东西向速率 (mm/yr)"},
        "velocity_gradient": {"type": ["string", "null"], "description": "LOS 速率梯度幅值"},
        "deformation_lineaments_geojson": {"type": ["string", "null"], "description": "LOS 形变线性体"},
        "ew_deformation_lineaments_geojson": {"type": ["string", "null"], "description": "东西向形变线性体 (需 2D 分解)"},
        "lineaments_activity_geojson": {"type": ["string", "null"], "description": "地形线性体活动性标签 (dv/activity_class)"},
        "subsidence_clusters_geojson": {"type": ["string", "null"], "description": "沉降连通域 (采空/漏斗候选)"},
        "overlay_png": {"type": ["string", "null"], "description": "融合叠加图件"},
        "timeseries_png": {"type": ["string", "null"], "description": "最大形变点时序曲线"},
        "rose_deformation_png": {"type": ["string", "null"], "description": "形变线性体走向玫瑰图"},
        "rose_ew_deformation_png": {"type": ["string", "null"], "description": "东西向形变线性体走向玫瑰图"}
      }
    },
    "structural_stats": {
      "type": "object",
      "description": "下游(geo-reporter/geo-exploration/geo-analyser)消费用的快速构造统计",
      "properties": {
        "n_lineaments": {"type": ["integer", "null"]},
        "total_lineament_length_km": {"type": ["number", "null"]},
        "lineament_density_mean": {"type": ["number", "null"]},
        "dominant_strikes_deg": {
          "type": ["array", "null"],
          "items": {"type": "number"},
          "description": "主构造方向(走向,度),按显著度降序"
        },
        "elevation_range_m": {
          "type": ["array", "null"],
          "items": {"type": "number"},
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "deposit_inference": {
      "type": ["object", "null"],
      "description": "基于构造特征的矿床类型推理结果(geo-stru 纯构造推理,非蚀变/地球化学)",
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "deposit_type": {"type": "string"},
              "confidence": {"type": "number"},
              "evidence": {"type": "array", "items": {"type": "string"}},
              "control_model": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        },
        "structural_control_summary": {"type": "string"},
        "primary_model": {"type": "string"},
        "primary_confidence": {"type": "number"}
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
