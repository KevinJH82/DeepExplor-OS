# ============================================================
# Copernicus（ESA Sentinel-1/2）账号
# 注册地址: https://dataspace.copernicus.eu/
# ============================================================
copernicus:
  username: your_email@example.com
  password: your_password

# ============================================================
# NASA Earthdata（Sentinel-1 via ASF + EMIT高光谱）
# 注册地址: https://urs.earthdata.nasa.gov/
# ============================================================
nasa_earthdata:
  username: your_earthdata_username
  password: your_earthdata_password
  token:    # 可选：从 https://urs.earthdata.nasa.gov/user_tokens 生成后填入，优先于密码认证

# ============================================================
# USGS EarthExplorer（Landsat 8/9）
# 注册地址: https://earthexplorer.usgs.gov/
# 注意: 需要额外申请M2M API访问权限
#   https://ers.cr.usgs.gov/profile/access
# ============================================================
usgs:
  username: your_usgs_username
  password: your_usgs_password

# ============================================================
# Google Earth Engine — 服务账号认证
# 申请步骤：
#   1. Google Cloud Console 创建项目并启用 Earth Engine API
#      https://console.cloud.google.com/
#   2. 创建服务账号，下载 JSON 密钥文件
#      IAM & Admin → Service Accounts → Create → Keys → JSON
#   3. 在 GEE 控制台注册该服务账号（非商业用途免费）
#      https://code.earthengine.google.com/register
# ============================================================
google_earth_engine:
  service_account_email: your-service-account@your-project.iam.gserviceaccount.com
  service_account_key_path: /path/to/your-service-account-key.json

# ============================================================
# 下载任务默认配置
# 运行 python3 main.py 时无需再传命令行参数
# 命令行参数优先级高于此处配置
# ============================================================
task:
  kml: /path/to/your/area.kml   # KML文件或文件夹路径
  sensor:
    - dem                        # 可选: dem sentinel2 sentinel1 landsat emit gee_sentinel2 ...
  output: ./downloads
  start:                         # 光学/SAR需填写，DEM可留空，格式 YYYY-MM-DD
  end:
  cloud: 20                      # 光学影像最大云量（%）
  max_items: 5                   # 每区域每传感器最多下载景数
  clip: true                     # 下载后是否裁剪到KML范围
  point_buffer: 0.1              # KML点要素缓冲半径（度，约11km）
  # GEE 自定义数据集参数（仅 sensor 包含 gee_custom 时需填写）
  # gee_collection_id: LANDSAT/LE07/C02/T1_L2
  # gee_bands: []                # 留空表示下载全部波段
  # gee_scale: 30                # 下载像素尺寸（米）

